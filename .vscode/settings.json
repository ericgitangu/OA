{
  "python.defaultInterpreterPath": "python3",
  "[markdown]": {
    "editor.defaultFormatter": "vscode.markdown-language-features",
    "editor.formatOnSave": true
  },
  "markdownlint.config": {
    "extends": "${workspaceFolder}/.markdownlint.yaml"
  },
  "files.exclude": {
    "**/__pycache__": true,
    "**/.pytest_cache": true,
    "**/target": true,
    "**/build": true,
    "**/node_modules": true
  }
}
